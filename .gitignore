# =============================================================================
# Agents.gitignore — AI Coding Agents & Assistants
# https://github.com/Fellowship-dev/agents-gitignore
#
# A comprehensive .gitignore for all known AI coding tools.
# Copy what you need, or use the whole file. See README for details.
#
# Inspired by https://github.com/github/gitignore/pull/4719
# =============================================================================

# -----------------------------------------------------------------------------
# Claude Code (Anthropic)
# https://docs.anthropic.com/en/docs/claude-code
# -----------------------------------------------------------------------------
CLAUDE.md
.claude/


# -----------------------------------------------------------------------------
# OpenAI Codex CLI
# https://github.com/openai/codex
# -----------------------------------------------------------------------------
AGENTS.md
AGENTS.override.md
codex.md
.codex/


# -----------------------------------------------------------------------------
# Google Gemini CLI
# https://github.com/google-gemini/gemini-cli
# -----------------------------------------------------------------------------
GEMINI.md
.gemini/


# -----------------------------------------------------------------------------
# Cursor (Anysphere)
# https://docs.cursor.com
# -----------------------------------------------------------------------------
.cursor/
.cursorrules
.cursorignore
.cursorindexingignore


# -----------------------------------------------------------------------------
# Windsurf (Codeium)
# https://docs.codeium.com/windsurf
# -----------------------------------------------------------------------------
.windsurf/
.windsurfrules


# -----------------------------------------------------------------------------
# GitHub Copilot
# https://docs.github.com/en/copilot
# Note: .github/copilot-instructions.md lives inside .github/ which you may
# already track. Add it explicitly if you want to ignore Copilot instructions.
# -----------------------------------------------------------------------------
# .github/copilot-instructions.md
# .github/instructions/
.copilotignore


# -----------------------------------------------------------------------------
# Aider (aider-chat)
# https://aider.chat
# -----------------------------------------------------------------------------
.aider*
.aiderignore


